<Window x:Class="lab5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab5"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl>

            <TabItem Header="Books">
                <Grid>
                    <DataGrid x:Name="BooksGrid"
                      AutoGenerateColumns="True"
                      Margin="10"/>
                </Grid>
            </TabItem>

            <TabItem Header="Publishers">
                <Grid>
                    <DataGrid x:Name="PublishersGrid"
                      AutoGenerateColumns="True"
                      Margin="10"/>
                </Grid>
            </TabItem>

            <TabItem Header="Books after 2016">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Show"
                    Width="120"
                    Height="30"
                    Click="ShowBooksAfter2020_Click"/>

                    <DataGrid x:Name="BooksAfter2020Grid"
                      Grid.Row="1"
                      Margin="0,10,0,0"
                      AutoGenerateColumns="True"/>

                </Grid>

            </TabItem>

            <TabItem Header="Books count">

                <Grid Margin="10">

                    <StackPanel>

                        <Button Content="Count books"
                        Width="150"
                        Height="30"
                        Click="CountBooks_Click"/>

                        <TextBlock x:Name="CountText"
                           FontSize="18"
                           Margin="0,20,0,0"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <TabItem Header="SQL query(1988 year)">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Execute SQL"
                    Width="150"
                    Height="30"
                    Click="ExecuteSql_Click"/>

                    <DataGrid x:Name="SqlGrid"
                      Grid.Row="1"
                      Margin="0,10,0,0"
                      AutoGenerateColumns="True"/>

                </Grid>

            </TabItem>

        </TabControl>
    </Grid>
</Window>
